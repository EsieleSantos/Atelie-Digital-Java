import java.io.*;

public class SistemaAtelie {

    public static void main(String[] args) {
        // 1. Primeiro, vamos garantir que existe um arquivo para ler
        prepararArquivoTeste();

        // 2. Agora, executamos a análise (o "momento Ciência de Dados")
        analisarProdutividade();
    }

    public static void analisarProdutividade() {
        int totalPecas = 0;
        String arquivoNome = "relatorio_ateliê.txt";

        System.out.println("🔍 Iniciando leitura do arquivo: " + arquivoNome);

        try (BufferedReader br = new BufferedReader(new FileReader(arquivoNome))) {
            String linha;
            while ((linha = br.readLine()) != null) {
                // Filtro lógico: conta apenas linhas que confirmam a conclusão
                if (linha.toLowerCase().contains("concluída") || linha.toLowerCase().contains("concluida")) {
                    totalPecas++;
                }
            }

            System.out.println("\n====================================");
            System.out.println("📊 DASHBOARD DO ATELIÊ");
            System.out.println("Status: Análise Finalizada");
            System.out.println("Produção Total: " + totalPecas + " item(ns)");
            System.out.println("====================================\n");

        } catch (IOException e) {
            System.err.println("❌ Erro ao processar os dados: " + e.getMessage());
        }
    }

    private static void prepararArquivoTeste() {
        // Este método apenas cria um arquivo de exemplo se ele não existir
        try (PrintWriter pw = new PrintWriter(new FileWriter("relatorio_ateliê.txt", true))) {
            pw.println("2026-05-07: Peça Concluída - Bordado Floral");
            pw.println("2026-05-07: Início de costura - Saia");
            pw.println("2026-05-07: Peça Concluída - Ajuste de barra");
            System.out.println("✅ Arquivo atualizado com novos dados de teste.");
        } catch (IOException e) {
            System.out.println("Erro ao preparar teste: " + e.getMessage());
        }
    }
}